# =============================================
# 若依接口测试框架 - 预发布环境配置
# 使用方式: ENV=staging pytest tests/
# 或: python run.py run --env=staging
# =============================================

# 若依后端地址
BASE_URL=http://localhost:8080

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=ry-vue
DB_USER=root
DB_PASSWORD=123456

# 日志级别
LOG_LEVEL=INFO

# 请求超时（秒）
DEFAULT_TIMEOUT=30
