# =============================================
# 若依接口测试框架 - 环境变量配置
# 使用前复制为 .env 并修改实际值
# =============================================

# 若依后端地址（必填）
BASE_URL=http://localhost

# 管理员账号（默认）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# MySQL 数据库配置（若依数据库，用于数据验证）
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=ry-vue
DB_USER=root
DB_PASSWORD=root

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 请求超时（秒）
DEFAULT_TIMEOUT=30
