# =============================================
# 若依接口测试框架 - 环境变量模板
# 复制为 .env 后修改实际值
# cp .env.example .env
# =============================================

# 若依后端地址
BASE_URL=http://your-server-ip:8080

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your-database-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 请求超时（秒）
DEFAULT_TIMEOUT=30
